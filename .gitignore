.claude/telegram/queue.json.tmp
.claude/channels/
Tools/mac-mini-deploy/gws/
Tools/google-workspace-cli/
Tools/mac-mini-deploy/gws/
Tools/mac-mini-deploy/.mcp.json

# --- PRIVATE: Autonomous logs ---
.claude/autonomous/logs/

# --- PRIVATE: Large media files ---
Projects/ICS/IMG_2895.MOV
Projects/ICS/video-frames/

# --- PRIVATE: Machine-specific config ---
.claude/settings.local.json
.claude/config.local.json
.claude/config.ps1

# --- PRIVATE: Project-specific folders with client data ---
Projects/toronto-move/
Projects/hamilton-campaign/

# --- PRIVATE: Obsidian config ---
.obsidian/

# --- PRIVATE: Misc personal ---
meditations/
Health/
Archive/
HOME.md
CHIEF-OF-STAFF.md
